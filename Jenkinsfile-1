pipeline {
  agent any

  environment {
    // ---- Docker Hub image to pull/run ----
    DOCKERHUB_USER = "saumy123"
    IMAGE_REPO     = "basic-java-hello"
    IMAGE_TAG      = "latest"
    IMAGE_REF      = "docker.io/${DOCKERHUB_USER}/${IMAGE_REPO}:${IMAGE_TAG}"

    // ---- Podman remote (your Windows -> WSL podman machine root connection) ----
    PODMAN_HOST     = "ssh://root@127.0.0.1:64000/run/podman/podman.sock"
    PODMAN_IDENTITY = "C:\\Users\\saumyver\\.local\\share\\containers\\podman\\machine\\machine"
  }

  options { timestamps() }

  stages {
    stage('Podman precheck') {
      steps {
        bat """
          set CONTAINER_HOST=%PODMAN_HOST%
          set CONTAINER_SSHKEY=%PODMAN_IDENTITY%
          podman version
          podman info
        """
      }
    }

    /*
      Login is ONLY needed if the Docker Hub repo is private OR you are rate-limited.
      Your earlier builds failed due to invalid username/password, so this stage
      is made OPTIONAL and controlled by a boolean parameter.
    */
    stage('Login to Docker Hub (optional)') {
  when { expression { return params.DOCKERHUB_LOGIN } }
  steps {
    withCredentials([usernamePassword(credentialsId: 'dockerhub-creds',
                                      usernameVariable: 'DH_USER',
                                      passwordVariable: 'DH_PASS')]) {
      powershell '''
        $ErrorActionPreference = "Stop"

        $env:CONTAINER_HOST   = $env:PODMAN_HOST
        $env:CONTAINER_SSHKEY = $env:PODMAN_IDENTITY

        # Send password/token via stdin safely
        $env:DH_PASS | podman login docker.io -u $env:DH_USER --password-stdin
      '''
    }
  }
}

    stage('Pull image') {
      steps {
        bat """
          set CONTAINER_HOST=%PODMAN_HOST%
          set CONTAINER_SSHKEY=%PODMAN_IDENTITY%
          echo Pulling %IMAGE_REF%
          podman pull %IMAGE_REF%
          podman image inspect %IMAGE_REF%
        """
      }
    }

    stage('Run (smoke test)') {
      steps {
        powershell '''
          $ErrorActionPreference = "Stop"
          $env:CONTAINER_HOST   = $env:PODMAN_HOST
          $env:CONTAINER_SSHKEY = $env:PODMAN_IDENTITY

          # HelloWorld container prints and exits
          podman run --rm $env:IMAGE_REF | Out-Host
        '''
      }
    }
  }

  // No logout step (it caused noisy failures and isn't required)
  parameters {
    booleanParam(name: 'DOCKERHUB_LOGIN',
                 defaultValue: false,
                 description: 'Enable only if the Docker Hub repo is PRIVATE or pulls are rate-limited. Requires valid Jenkins credential "dockerhub-creds" (use a Docker Hub access token).')
  }
}
